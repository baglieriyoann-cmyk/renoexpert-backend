# RénoExpert v2.0 - Variables d'environnement

# Clé API Anthropic (à obtenir sur console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxx

# Port du serveur (Railway/Heroku définit automatiquement)
PORT=3000

# Environnement
NODE_ENV=production

# Stripe (pour paiements Premium/Agent/MB)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# Configuration Email (optionnel - pour reset password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@renoexpert.fr
SMTP_PASS=xxxxxxxx
